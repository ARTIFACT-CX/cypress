# Cypress local overrides — copy to .env and uncomment what you need.
# .env is gitignored; .env.example is the source of truth for what's
# wired up. Defaults in code are sensible; nothing here is required.

# --- Model selection ------------------------------------------------
# Force a moshi backend, bypassing platform autoselect (default: mlx
# on Apple Silicon, torch elsewhere). Will move into the settings UI
# once it lands.
# CYPRESS_MOSHI_BACKEND=mlx|torch

# Pull moshi weights from a non-default HF repo. Today this is the
# only way to switch quantization (q4/q8/bf16); a future change moves
# the per-quant variants into the catalog as separate entries.
# CYPRESS_MOSHI_REPO=kyutai/moshiko-mlx-q8

# Force the torch device, bypassing autodetection (mps → cuda → cpu).
# Useful when MPS regresses on a particular op or for CPU benchmarking.
# CYPRESS_DEVICE=mps|cuda|cpu

# --- Performance tuning --------------------------------------------
# Opt-in MPS high-watermark ratio. When set, lifts the PyTorch MPS
# memory cap from the default 0 → this value (e.g. 0.0 disables the
# upper bound). Apple Silicon only.
# CYPRESS_MPS_HIGH_RATIO=0.0

# --- External (standard, just respected) ---------------------------
# HuggingFace cache root. Honored by the catalog's "downloaded?"
# probe and by the worker's hf_hub_download calls.
# HF_HOME=~/.cache/huggingface
# HUGGINGFACE_HUB_CACHE=~/.cache/huggingface/hub

# Some NVIDIA-only flows (PersonaPlex, future) need a HF token to
# pull gated weights.
# HF_TOKEN=hf_...

# Tauri dev server host (only relevant when running `pnpm tauri dev`).
# TAURI_DEV_HOST=0.0.0.0
