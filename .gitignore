# Dependencies
node_modules/

# Build outputs
dist/
build/
app/src-tauri/target/
app/src-tauri/gen/
app/.vite/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Claude Code per-machine settings
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# uv keeps its lockfile in the repo, but ignore the cache
.uv-cache/

# Models / large files. Extension-based rules cover weight files wherever
# they land; we don't blanket-ignore `models/` because that's also the name
# of our worker/models source feature.
*.gguf
*.safetensors
*.bin
*.pt
*.pth
*.onnx
