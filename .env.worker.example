# Cypress worker container env — copy to .env.worker and fill in.
# Loaded by compose.yml's `env_file` directive. .env.worker is
# gitignored; .env.worker.example is the source of truth for what's
# wired up.
#
# This file is for the *remote* worker (the GPU box / pod). Don't
# confuse it with .env at the repo root, which configures the laptop-
# side Cypress app.

# --- Required -----------------------------------------------------
# Bearer token validated on every gRPC call. Generate with:
#   openssl rand -hex 32
# Must match CYPRESS_REMOTE_TOKEN on the laptop side. Treat like an
# API key — anyone with the token can drive the worker.
CYPRESS_TOKEN=replace-with-shared-secret

# --- Optional -----------------------------------------------------
# Hugging Face cache root inside the container. Mapped to a host volume
# in compose.yml so weights survive container restarts.
# HF_HOME=/var/cache/huggingface

# Pull moshi weights from a non-default HF repo. Today this is the
# only way to switch quantization (q4/q8/bf16) on the worker side; a
# future change moves the per-quant variants into the catalog.
# CYPRESS_MOSHI_REPO=kyutai/moshiko-pytorch-bf16   # male voice (default: moshika, female)

# Some NVIDIA-only flows (PersonaPlex, future) need a HF token to pull
# gated weights. Not required for moshi.
# HF_TOKEN=hf_...
